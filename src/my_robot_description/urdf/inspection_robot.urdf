<?xml version="1.0"?>

<robot name="inspection_robot">

  <!-- Base Link -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="2 2 1"/>
      </geometry>

      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
  </link>

  <!-- Camera Link -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.5 0.5 0.5"/>
      </geometry>

      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
  </link>

  <!-- Fixed Joint -->
  <joint name="camera_joint" type="fixed">

    <parent link="base_link"/>

    <child link="camera_link"/>

    <origin xyz="0 0 1.2" rpy="0 0 0"/>

  </joint>

</robot>